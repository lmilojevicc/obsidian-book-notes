{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES2021",
		"strict": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"moduleResolution": "node",
		"isolatedModules": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"lib": ["ES2021", "DOM"]
	},
	"include": ["src/**/*.ts"]
}
